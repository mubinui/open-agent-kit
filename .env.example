# Open Agent Kit — environment configuration
# Copy to .env and fill in what you need. Everything has a sensible default
# except the LLM API key.

# ============================================================
# LLM provider (required for real agent responses)
# ============================================================
# OpenRouter is the default provider (https://openrouter.ai/keys).
OPENROUTER_API_KEY=
# Default model id (any LiteLLM-supported model works)
OPENROUTER_MODEL=openai/gpt-oss-20b
# LLM_PROVIDER=openrouter

# ============================================================
# Application
# ============================================================
# APP_PORT=8000
# LOG_LEVEL=INFO
# development = no auth required; production = auth enforced
# ENVIRONMENT=development
# Comma-separated allowed CORS origins, or * for all
# FRONTEND_URL=*

# ============================================================
# Database (SQLite by default — zero config)
# ============================================================
# DATABASE_URL=sqlite:///./data/oak.db
# For PostgreSQL (e.g. with `docker compose --profile postgres up`):
# DATABASE_URL=postgresql://oak:oak_pass@localhost:5432/oak
# OAK_AUTO_MIGRATE=true

# ============================================================
# Authentication (optional)
# ============================================================
# Create the first admin account on boot (only if no users exist)
# OAK_ADMIN_USERNAME=admin
# OAK_ADMIN_PASSWORD=change-me
# JWT signing key — set a strong random value in production
# SECRET_KEY=change-this-in-production

# Optional Keycloak SSO
# KEYCLOAK_ENABLED=false
# KEYCLOAK_SERVER_URL=http://localhost:8080
# KEYCLOAK_REALM=my-realm
# KEYCLOAK_CLIENT_ID=oak-frontend
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_ADMIN_CLIENT_ID=oak-admin
# KEYCLOAK_ADMIN_CLIENT_SECRET=

# ============================================================
# Optional services
# ============================================================
# Redis cache
# REDIS_URL=redis://localhost:6379/0

# Qdrant vector store
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=knowledge_base

# External RAG pipeline service (powers the rag_* tools)
# RAG_PIPELINE_ENABLED=false
# RAG_PIPELINE_BASE_URL=http://localhost:8003
# RAG_PIPELINE_API_KEY=
# RAG_PIPELINE_DEFAULT_COLLECTION=knowledge_base

# ============================================================
# Observability
# ============================================================
# ENABLE_METRICS=true
# PROMETHEUS_PORT=9090
# OTEL_EXPORTER_OTLP_ENDPOINT=

# ============================================================
# Integrations (Gmail tools via Google OAuth 2.0)
# ============================================================
# Create OAuth client credentials (type: Web application) in Google Cloud Console,
# add the redirect URI below to its authorized redirect URIs, and enable the Gmail API.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/gmail/callback
# Required for storing Gmail tokens (Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# ENCRYPTION_KEY=

# Allow CrewAI tasks to block on stdin for human input (unsafe on headless servers)
# OAK_ALLOW_HUMAN_INPUT=false
