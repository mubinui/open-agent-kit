# ============================================================================
# ORCHESTRATION SERVICE ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update with your actual values
# Required variables are marked with [REQUIRED]
# Optional variables have default values or can be omitted
# ============================================================================

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Provider API Keys [REQUIRED - At least one provider]
# ----------------------------------------------------------------------------
# Get your API keys from:
# - OpenRouter: https://openrouter.ai/keys
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys

OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------------------------------------------------------
# Database Configuration [REQUIRED]
# ----------------------------------------------------------------------------
# PostgreSQL connection string for conversation storage
# Format: postgresql://username:password@host:port/database
# For local development with Docker: postgresql://postgres:postgres@localhost:5432/orchestration

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchestration

# MongoDB connection string for chatbot workflow persistence [OPTIONAL]
# Format: mongodb://username:password@host:port/database
# For local development with Docker: mongodb://orchestrator:orchestrator_pass@localhost:27017/orchestration
# Leave empty to disable MongoDB persistence (chatbot workflows will fail)

# MONGODB_URL=mongodb://orchestrator:orchestrator_pass@localhost:27017/orchestration
# MONGODB_DATABASE=orchestration

# ----------------------------------------------------------------------------
# Redis Configuration [REQUIRED]
# ----------------------------------------------------------------------------
# Redis connection string for caching
# Format: redis://host:port/db_number
# For local development with Docker: redis://localhost:6379/0

REDIS_URL=redis://localhost:6379/0

# ============================================================================
# OPTIONAL CONFIGURATION (with defaults)
# ============================================================================

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Maximum conversation turns before auto-termination
MAX_CONVERSATION_TURNS=20

# Timeout for agent responses in seconds
RESPONSE_TIMEOUT_SECONDS=120

# Maximum concurrent sessions
MAX_CONCURRENT_SESSIONS=100

# Agent timeout in seconds
AGENT_TIMEOUT_SECONDS=300

# Environment: development, staging, production
ENVIRONMENT=development

# ----------------------------------------------------------------------------
# API Server Configuration
# ----------------------------------------------------------------------------
# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Number of API worker processes (0 = auto-detect CPU cores)
API_WORKERS=0

# Enable API documentation endpoints (/docs, /redoc)
ENABLE_API_DOCS=true

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ----------------------------------------------------------------------------
# Message Broker Configuration [OPTIONAL]
# ----------------------------------------------------------------------------
# RabbitMQ connection string for async processing
# Format: amqp://username:password@host:port/vhost
# Leave empty to disable async processing
# For local development with Docker: amqp://guest:guest@localhost:5672/

RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# RabbitMQ connection pool settings
RABBITMQ_MAX_CONNECTIONS=10
RABBITMQ_MAX_CHANNELS=100

# RabbitMQ queue configuration
RABBITMQ_QUEUE_NAME=orchestration_tasks
RABBITMQ_EXCHANGE_NAME=orchestration
RABBITMQ_ROUTING_KEY=task

# Enable dead letter queue for failed messages
ENABLE_DLQ=true

# ----------------------------------------------------------------------------
# Vector Database Configuration [OPTIONAL]
# ----------------------------------------------------------------------------
# Default vector database: chromadb, pgvector, qdrant
DEFAULT_VECTOR_DB=chromadb

# ChromaDB (embedded, no external service needed)
CHROMADB_PATH=./data/chromadb

# PGVector (requires PostgreSQL with pgvector extension)
PGVECTOR_URL=postgresql://postgres:postgres@localhost:5432/vectordb

# Qdrant (standalone or cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding model for vector databases
EMBEDDING_MODEL=all-mpnet-base-v2

# Document chunk size for RAG
CHUNK_TOKEN_SIZE=2000

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# JWT algorithm
JWT_ALGORITHM=HS256

# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for sensitive data (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-encryption-key-base64-encoded

# Enable API key authentication
ENABLE_API_KEY_AUTH=true

# Enable JWT authentication
ENABLE_JWT_AUTH=true

# Enable RBAC (Role-Based Access Control)
ENABLE_RBAC=false

# ----------------------------------------------------------------------------
# Rate Limiting Configuration
# ----------------------------------------------------------------------------
# Default rate limits for unauthenticated requests
REQUESTS_PER_MINUTE=60
REQUESTS_PER_HOUR=1000

# Rate limits for authenticated API key requests
API_KEY_REQUESTS_PER_MINUTE=100
API_KEY_REQUESTS_PER_HOUR=5000

# Enable rate limiting
ENABLE_RATE_LIMITING=true

# ----------------------------------------------------------------------------
# Caching Configuration
# ----------------------------------------------------------------------------
# Enable multi-layer caching
ENABLE_CACHING=true

# Session cache TTL in seconds
SESSION_CACHE_TTL=3600

# LLM response cache TTL in seconds
LLM_CACHE_TTL=86400

# Embedding cache TTL in seconds
EMBEDDING_CACHE_TTL=604800

# Cache key prefix
CACHE_KEY_PREFIX=orchestration

# ----------------------------------------------------------------------------
# Observability Configuration
# ----------------------------------------------------------------------------
# Enable telemetry and metrics
ENABLE_TELEMETRY=true
ENABLE_METRICS=true

# Prometheus metrics port
PROMETHEUS_PORT=9090

# OpenTelemetry configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=orchestration-service
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp

# Enable distributed tracing
ENABLE_TRACING=false

# Trace sampling rate (0.0 to 1.0)
TRACE_SAMPLE_RATE=0.1

# ----------------------------------------------------------------------------
# Audit Logging Configuration
# ----------------------------------------------------------------------------
# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# Audit log retention in days
AUDIT_LOG_RETENTION_DAYS=90

# Log sensitive data (disable in production)
LOG_SENSITIVE_DATA=false

# ----------------------------------------------------------------------------
# LLM Provider Configuration
# ----------------------------------------------------------------------------
# Default LLM provider (must match provider_id in configs/api_providers.json)
DEFAULT_LLM_PROVIDER=openrouter

# Default model from OpenRouter
DEFAULT_LLM_MODEL=openai/gpt-oss-20b
OPENROUTER_MODEL=openai/gpt-oss-20b

# Default temperature
DEFAULT_TEMPERATURE=0.7

# Default max tokens
DEFAULT_MAX_TOKENS=500

# Enable LLM response caching
ENABLE_LLM_CACHING=true

# LLM request timeout in seconds
LLM_REQUEST_TIMEOUT=120

# LLM retry attempts
LLM_RETRY_ATTEMPTS=3

# LLM retry delay in seconds
LLM_RETRY_DELAY=1

# ----------------------------------------------------------------------------
# Configuration Hot Reload
# ----------------------------------------------------------------------------
# Enable automatic configuration reload on file changes
ENABLE_CONFIG_HOT_RELOAD=true

# Configuration file watch interval in seconds
CONFIG_WATCH_INTERVAL=5

# ----------------------------------------------------------------------------
# Database Connection Pool
# ----------------------------------------------------------------------------
# PostgreSQL connection pool size
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Enable SQL query logging (disable in production)
DB_ECHO=false

# ----------------------------------------------------------------------------
# Redis Connection Pool
# ----------------------------------------------------------------------------
# Redis connection pool size
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ----------------------------------------------------------------------------
# Admin UI Configuration
# ----------------------------------------------------------------------------
# Admin UI URL (for CORS)
ADMIN_UI_URL=http://localhost:4200

# Enable admin UI features
ENABLE_ADMIN_UI=true

# ============================================================================
# ADVANCED OPTIONAL CONFIGURATION
# ============================================================================

# ----------------------------------------------------------------------------
# Secret Management [OPTIONAL]
# ----------------------------------------------------------------------------
# Secret manager type: environment, aws, azure, hashicorp
SECRET_MANAGER_TYPE=environment

# AWS Secrets Manager (if using SECRET_MANAGER_TYPE=aws)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_SECRET_NAME=orchestration-service/secrets

# Azure Key Vault (if using SECRET_MANAGER_TYPE=azure)
# AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/
# AZURE_CLIENT_ID=your_azure_client_id
# AZURE_CLIENT_SECRET=your_azure_client_secret
# AZURE_TENANT_ID=your_azure_tenant_id

# HashiCorp Vault (if using SECRET_MANAGER_TYPE=hashicorp)
# VAULT_URL=http://localhost:8200
# VAULT_TOKEN=your_vault_token
# VAULT_MOUNT_POINT=secret
# VAULT_SECRET_PATH=orchestration-service

# ----------------------------------------------------------------------------
# Feature Flags [OPTIONAL]
# ----------------------------------------------------------------------------
# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable code execution in agents
ENABLE_CODE_EXECUTION=false

# Enable nested chat patterns
ENABLE_NESTED_CHAT=true

# Enable group chat patterns
ENABLE_GROUP_CHAT=true

# ----------------------------------------------------------------------------
# Performance Tuning [OPTIONAL]
# ----------------------------------------------------------------------------
# Enable async processing
ENABLE_ASYNC_PROCESSING=true

# Async worker count
ASYNC_WORKER_COUNT=4

# Enable request compression
ENABLE_COMPRESSION=true

# Enable response streaming
ENABLE_STREAMING=false

# ----------------------------------------------------------------------------
# Development Settings [OPTIONAL]
# ----------------------------------------------------------------------------
# Enable debug mode (DO NOT use in production)
DEBUG=false

# Enable auto-reload on code changes
AUTO_RELOAD=true

# Enable profiling
ENABLE_PROFILING=false

# Profile output directory
PROFILE_OUTPUT_DIR=./profiles

# ----------------------------------------------------------------------------
# Testing Configuration [OPTIONAL]
# ----------------------------------------------------------------------------
# Test database URL (used by pytest)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchestration_test

# Test Redis URL
# TEST_REDIS_URL=redis://localhost:6379/1

# Enable test mode
# TEST_MODE=false

# ============================================================================
# NOTES
# ============================================================================
# 1. Generate secure keys:
#    - SECRET_KEY: openssl rand -hex 32
#    - ENCRYPTION_KEY: openssl rand -base64 32
#
# 2. For production:
#    - Use strong, unique keys
#    - Enable HTTPS/TLS
#    - Use external secret management (AWS/Azure/Vault)
#    - Disable DEBUG and LOG_SENSITIVE_DATA
#    - Enable RBAC and rate limiting
#    - Use production-grade database and Redis instances
#
# 3. For local development:
#    - Use docker-compose to start PostgreSQL, Redis, RabbitMQ
#    - Keep default values for most settings
#    - Enable DEBUG and AUTO_RELOAD for faster development
#
# 4. Required services:
#    - PostgreSQL 14+ (required)
#    - Redis 7+ (required)
#    - MongoDB 6.0+ (optional, for chatbot workflows)
#    - RabbitMQ 3.12+ (optional, for async processing)
#    - Vector DB (optional, ChromaDB works without external service)
#
# 5. MongoDB setup:
#    - Run scripts/init_mongodb.py to create collections and indexes
#    - Configure workflows with persistence: "mongo_only" for chatbot workflows
#    - TTL indexes automatically expire old data (sessions: 24h, messages: 7d)
# ============================================================================
