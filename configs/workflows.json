  "workflows": [
    {
      "id": "demo_multi_agent",
      "name": "Demo Multi-Agent Assistant",
      "description": "Multi-agent assistant that routes to web search, knowledge base, or calculator specialists",
      "enabled": true,
      "pattern": "selector",
      "topology": {
        "type": "graph",
        "nodes": [
          {
            "id": "demo_selector_agent",
            "agent_id": "demo_selector_agent",
            "description": "Routes to specialists"
          },
          {
            "id": "search_assistant",
            "agent_id": "search_assistant",
            "description": "Web search specialist"
          },
          {
            "id": "rag_assistant",
            "agent_id": "rag_assistant",
            "description": "Knowledge base specialist"
          },
          {
            "id": "calculator_agent",
            "agent_id": "calculator_agent",
            "description": "Math specialist"
          }
        ],
        "edges": [],
        "entry_node": "demo_selector_agent",
        "domain_agents": [
          {
            "id": "search_assistant",
            "name": "SearchAssistant",
            "domain": "web_search"
          },
          {
            "id": "rag_assistant",
            "name": "RAGAssistant",
            "domain": "knowledge_base"
          },
          {
            "id": "calculator_agent",
            "name": "CalculatorAgent",
            "domain": "math"
          }
        ],
        "routing_method": "llm"
      },
      "execution_config": {
        "max_turns": 15,
        "timeout_seconds": 300,
        "enable_streaming": false
      },
      "persistence": "postgres",
      "workflow_type": "chatbot"
    },
    {
      "id": "simple_search",
      "name": "Simple Search Assistant",
