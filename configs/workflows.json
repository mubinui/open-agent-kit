      "id": "requisition_assistant",
      "name": "Requisition Assistant",
      "description": "An assistant that queries the Requisition API to fetch and explain procurement requisition details. Ask about any requisition by number (e.g., REQ20250010638).",
      "pattern": "two_agent",
      "entry_agent_id": "user_proxy",
      "recipient_agent_id": "requisition_agent",
      "max_turns": 6,
      "summary_method": "last_msg",
      "enabled": true,
      "metadata": {
        "use_case": "procurement",
        "complexity": "simple",
        "external_api": "requisition"
      },
      "workflow_type": "sequential",
      "persistence": "mongo_only",
      "version": 1,
      "last_updated": "2024-12-08T00:00:00Z"
    },
    {
      "id": "procurement_chatbot",
      "name": "Procurement Chatbot",
      "description": "Multi-agent chatbot for procurement queries. Routes to specialized agents for requisitions, purchase orders, and framework agreements.",
      "pattern": "selector",
      "entry_agent_id": "selector_agent",
      "max_turns": 10,
      "summary_method": "last_msg",
      "enabled": true,
      "default": true,
      "selector_config": {
        "routing_agents": {
          "requisition": "requisition_domain_agent",
          "purchase_order": "purchase_order_agent",
          "framework_agreement": "framework_agreement_agent"
        },
        "default_agent": "selector_agent",
        "max_routing_attempts": 3
      },
      "metadata": {
        "use_case": "procurement",
        "complexity": "medium"
      },
      "workflow_type": "chatbot",
      "persistence": "mongo_only",
      "version": 1,
      "last_updated": "2024-12-10T00:00:00Z"
    }
  ]
