    {
      "id": "constrained_group_chat",
      "name": "Constrained Group Discussion",
      "description": "Group chat with controlled speaker transitions for structured discussions",
      "pattern": "group_chat",
      "entry_agent_id": "moderator",
      "enabled": true,
      "group_chat": {
        "agents": [
          "moderator",
          "expert_1",
          "expert_2",
          "summarizer"
        ],
        "max_round": 20,
        "speaker_selection_method": "auto",
        "allowed_transitions": {
          "moderator": [
            "expert_1",
            "expert_2",
            "summarizer"
          ],
          "expert_1": [
            "expert_2",
            "moderator"
          ],
          "expert_2": [
            "expert_1",
            "moderator"
          ],
          "summarizer": [
            "moderator"
          ]
        },
        "speaker_transitions_type": "allowed",
        "send_introductions": false,
        "admin_name": "DiscussionManager",
        "select_speaker_message_template": null,
        "select_speaker_auto_verbose": false
      },
      "metadata": {
        "use_case": "structured_discussion",
        "complexity": "high"
      },
      "workflow_type": "tree",
      "persistence": "mongo_only",
      "version": 1,
      "last_updated": "2024-11-16T00:00:00Z"
    },
