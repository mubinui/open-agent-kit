    {
      "id": "nested_research_assistant",
      "name": "Research Assistant with Nested Verification",
      "description": "Assistant that triggers nested fact-checking conversations when needed",
      "pattern": "nested",
      "entry_agent_id": "research_assistant",
      "enabled": false,
      "nested_chats": [
        {
          "trigger_agent_id": "research_assistant",
          "nested_chats": [
            {
              "recipient": "fact_checker",
              "message": "Verify the accuracy of the following information",
              "max_turns": 3,
              "summary_method": "last_msg"
            },
            {
              "recipient": "source_validator",
              "message": "Validate the credibility of sources",
              "max_turns": 2,
              "summary_method": "last_msg"
            }
          ],
          "trigger_condition": "fact check",
          "position": 2
        }
      ],
      "metadata": {
        "use_case": "research_with_verification",
        "complexity": "high",
        "note": "Disabled by default - requires proper nested chat setup"
      },
      "workflow_type": "custom",
      "persistence": "mongo_only",
      "version": 1,
      "last_updated": "2024-11-16T00:00:00Z"
    },
