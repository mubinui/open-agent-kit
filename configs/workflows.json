    {
      "id": "sequential_research",
      "name": "Sequential Research Workflow",
      "description": "Multi-step research workflow: reasoning -> knowledge retrieval -> response generation",
      "pattern": "sequential",
      "entry_agent_id": "reasoning_agent",
      "enabled": true,
      "steps": [
        {
          "sender_id": "reasoning_agent",
          "recipient_id": "user_proxy",
          "message": "Analyze the user's query and determine the information needed",
          "max_turns": 3,
          "summary_method": "last_msg",
          "carryover": false,
          "clear_history": false
        },
        {
          "sender_id": "knowledge_agent",
          "recipient_id": "user_proxy",
          "max_turns": 5,
          "summary_method": "reflection_with_llm",
          "carryover": true,
          "clear_history": false
        },
        {
          "sender_id": "response_agent",
          "recipient_id": "user_proxy",
          "message": "Generate a comprehensive response based on the retrieved knowledge",
          "max_turns": 3,
          "summary_method": "last_msg",
          "carryover": true,
          "clear_history": false
        }
      ],
      "metadata": {
        "use_case": "research_and_analysis",
        "complexity": "medium"
      },
      "workflow_type": "sequential",
      "persistence": "mongo_only",
      "version": 1,
      "last_updated": "2024-11-16T00:00:00Z"
    },
    {
