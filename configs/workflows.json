{
  "version": "2.0.0",
  "_schema": "oak-crewai-workflows",
  "_comment": "Example workflow definitions for Open Agent Kit.",
  "last_updated": "2026-07-11T00:00:00Z",
  "workflows": [
    {
      "id": "demo_multi_agent",
      "name": "Demo Multi-Agent Assistant",
      "description": "Multi-agent assistant that routes to web search, knowledge base, or calculator specialists",
      "enabled": true,
      "pattern": "selector",
      "topology": {
        "type": "graph",
        "nodes": [
          {
            "id": "demo_selector_agent",
            "agent_id": "demo_selector_agent",
            "description": "Routes to specialists"
          },
          {
            "id": "search_assistant",
            "agent_id": "search_assistant",
            "description": "Web search specialist"
          },
          {
            "id": "rag_assistant",
            "agent_id": "rag_assistant",
            "description": "Knowledge base specialist"
          },
          {
            "id": "calculator_agent",
            "agent_id": "calculator_agent",
            "description": "Math specialist"
          }
        ],
        "edges": [],
        "entry_node": "demo_selector_agent",
        "domain_agents": [
          {
            "id": "search_assistant",
            "name": "SearchAssistant",
            "domain": "web_search"
          },
          {
            "id": "rag_assistant",
            "name": "RAGAssistant",
            "domain": "knowledge_base"
          },
          {
            "id": "calculator_agent",
            "name": "CalculatorAgent",
            "domain": "math"
          }
        ],
        "routing_method": "llm"
      },
      "execution_config": {
        "max_turns": 15,
        "timeout_seconds": 300,
        "enable_streaming": false
      },
      "persistence": "postgres",
      "workflow_type": "chatbot"
    },
    {
      "id": "simple_search",
      "name": "Simple Search Assistant",
      "description": "Single agent for web search",
      "enabled": true,
      "pattern": "single",
      "topology": {
        "type": "single",
        "nodes": [
          {
            "id": "search_assistant",
            "agent_id": "search_assistant",
            "description": "Web search agent"
          }
        ],
        "entry_node": "search_assistant"
      },
      "execution_config": {
        "max_turns": 10,
        "timeout_seconds": 120
      },
      "persistence": "postgres",
      "workflow_type": "chatbot"
    },
    {
      "id": "rag_assistant",
      "name": "RAG Knowledge Assistant",
      "description": "Single agent with RAG capabilities",
      "enabled": true,
      "pattern": "single",
      "topology": {
        "type": "single",
        "nodes": [
          {
            "id": "rag_assistant",
            "agent_id": "rag_assistant",
            "description": "RAG assistant"
          }
        ],
        "entry_node": "rag_assistant"
      },
      "execution_config": {
        "max_turns": 10,
        "timeout_seconds": 180
      },
      "persistence": "postgres",
      "workflow_type": "chatbot"
    },
    {
      "id": "pipeline_example",
      "name": "Sequential Pipeline Example",
      "description": "Example of sequential agent execution",
      "enabled": false,
      "_comment": "Example workflow showing CrewAI's SequentialAgent pattern",
      "pattern": "sequential",
      "topology": {
        "type": "sequential",
        "nodes": [
          {
            "id": "search_assistant",
            "agent_id": "search_assistant",
            "description": "Search step"
          },
          {
            "id": "general_assistant",
            "agent_id": "general_assistant",
            "description": "Summary step"
          }
        ],
        "entry_node": "search_assistant",
        "pipeline": [
          {
            "agent_id": "search_assistant",
            "output_key": "search_results"
          },
          {
            "agent_id": "general_assistant",
            "instruction_override": "Summarize the search results: {search_results}"
          }
        ]
      },
      "execution_config": {
        "max_turns": 5,
        "timeout_seconds": 180
      },
      "persistence": "postgres",
      "workflow_type": "sequential"
    },
    {
      "id": "parallel_example",
      "name": "Parallel Execution Example",
      "description": "Example of parallel agent execution",
      "enabled": false,
      "_comment": "Example workflow showing CrewAI's ParallelAgent pattern",
      "pattern": "parallel",
      "topology": {
        "type": "graph",
        "nodes": [
          {
            "id": "search_assistant",
            "agent_id": "search_assistant",
            "description": "Search agent"
          },
          {
            "id": "rag_assistant",
            "agent_id": "rag_assistant",
            "description": "RAG agent"
          },
          {
            "id": "general_assistant",
            "agent_id": "general_assistant",
            "description": "Synthesis agent"
          }
        ],
        "entry_node": "general_assistant",
        "concurrent_agents": [
          {
            "agent_id": "search_assistant",
            "output_key": "web_results"
          },
          {
            "agent_id": "rag_assistant",
            "output_key": "kb_results"
          }
        ],
        "synthesizer": {
          "agent_id": "general_assistant",
          "instruction_override": "Combine results from web ({web_results}) and knowledge base ({kb_results})."
        }
      },
      "execution_config": {
        "max_turns": 3,
        "timeout_seconds": 240
      },
      "persistence": "postgres",
      "workflow_type": "custom"
    },
