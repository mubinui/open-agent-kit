      "id": "simple_assistant",
      "name": "Simple Assistant",
      "description": "A simple two-agent conversation between user and assistant",
      "pattern": "two_agent",
      "entry_agent_id": "user_proxy",
      "recipient_agent_id": "assistant",
      "max_turns": 10,
      "summary_method": "last_msg",
      "enabled": true,
      "metadata": {
        "use_case": "general_conversation",
        "complexity": "simple"
      },
      "workflow_type": "sequential",
      "persistence": "mongo_only",
      "version": 1,
      "last_updated": "2024-11-16T00:00:00Z"
    },
