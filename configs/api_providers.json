    {
      "id": "vllm",
      "name": "vLLM (Self-hosted)",
      "type": "llm",
      "description": "Self-hosted vLLM server for Gemma 3 12B with function calling.",
      "base_url_env": "VLLM_API_BASE",
      "default_base_url": "http://localhost:8000",
      "enabled": true,
      "priority": 2,
      "auth": {
        "scheme": "bearer",
        "env_var": "VLLM_API_KEY",
        "required": false,
        "gcloud_auth_env": "VLLM_USE_GCLOUD_AUTH"
      },
      "models": [
        {
          "name": "openai/gpt-oss-20b",
          "default": true,
          "litellm_string": "hosted_vllm/openai/gpt-oss-20b",
          "capabilities": [
            "chat",
            "function_calling",
            "reasoning"
          ],
          "deployment_flags": [
            "--enable-auto-tool-choice",
            "--tool-call-parser hermes",
            "--max-model-len 131072"
          ],
          "docker_image": "vllm/vllm-openai:latest",
          "gpu_requirements": "24GB+ VRAM (single A10/A100 or 2xRTX4090)",
          "notes": "Function calling requires --enable-auto-tool-choice flag"
        }
      ],
      "request_defaults": {
        "timeout_seconds": 180,
        "max_retries": 2
      }
    },
    {
      "id": "duckduckgo",
      "name": "DuckDuckGo Search",
      "type": "tool",
      "description": "DuckDuckGo Search API wrapper for real-time web search.",
      "library": "duckduckgo-search",
      "entrypoint": "src.agents.connectors.duckduckgo:DuckDuckGoConnector",
      "enabled": true,
      "settings": {
        "max_results": 3,
        "region": "wt-wt",
        "safesearch": "moderate"
      }
    }
  ],
  "provider_selection": {
    "primary": "openrouter",
    "fallback": "vllm",
    "strategy": "failover",
    "env_var": "LLM_PROVIDER"
  },
  "caching": {
    "backend": "redis",
    "enabled_env": "LITELLM_CACHE_ENABLED",
    "redis": {
      "host_env": "REDIS_HOST",
      "port_env": "REDIS_PORT",
      "password_env": "REDIS_PASSWORD"
    },
    "ttl_seconds": 3600
  }
