    {
      "_comment": "Requisition API Tools - External service for procurement requisitions",
      "id": "get_requisition_info",
      "name": "find_requisition_by_requisition_no",
      "description": "Find requisition by requisition no\n\nParameters:\n  - reqNo [query] (required)\n  - x-client-username [header] (optional): Username\n  - x-client-ref [header] (optional): Comma-separated roles",
      "entrypoint": "src.tools.api_tool_executor:execute_api_tool",
      "enabled": true,
      "settings": {
        "type": "api",
        "api_url": "http://10.42.65.155:8012/api/v1/requisition",
        "http_method": "GET",
        "auth_type": "none",
        "timeout": 30,
        "forward_user_context": true,
        "_swagger_metadata": {
          "operation_id": "getRequisitionInfo",
          "path": "/api/v1/requisition",
          "tags": ["requisition-controller"],
          "parameters": [
            {"name": "reqNo", "in": "query", "required": true, "schema": {"type": "string"}, "example": "REQ20250010638"},
            {"name": "x-client-username", "in": "header", "description": "Username", "required": false, "schema": {"type": "string"}},
            {"name": "x-client-ref", "in": "header", "description": "Comma-separated roles", "required": false, "schema": {"type": "string"}}
          ],
          "source_spec": "API Documentation"
        }
      }
    },
